JWT_SECRET=replace-with-strong-secret
APP_ENV=development
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_platform
EXECUTION_QUEUE=execution_queue
INGEST_QUEUE=ingest_queue
TENANT_TOKEN_PLAN_LIMIT=200000
USAGE_DAILY_DAYS=7
MAX_AGENT_ESTIMATED_TOKENS=120000
MAX_AGENT_EXPECTED_DURATION_MS=120000
MAX_AGENT_EXPECTED_FILES_CHANGED=40
MAX_AGENT_TOTAL_CHANGED_BYTES=5242880
MAX_AGENT_CONCURRENT_RUNNING_TASKS=5
MAX_AGENT_RUNTIME_TOKENS_USED=120000
MAX_AGENT_RUNTIME_DURATION_MS=120000
MAX_AGENT_RUNTIME_FILES_CHANGED=40
MAX_AGENT_EVALUATIONS_PER_MINUTE=60

# Optional OpenAI fallback in worker:
DEFAULT_LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
MAX_JOB_RETRIES=2
EXECUTION_DLQ=execution_dlq
INGESTION_DLQ=ingestion_dlq
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
RETRIEVAL_TOP_K=4
LANGGRAPH_BIND_HOST=127.0.0.1
LANGGRAPH_PORT=8001
QDRANT_BIND_HOST=127.0.0.1
QDRANT_PORT=6333
OLLAMA_BIND_HOST=127.0.0.1
OLLAMA_PORT=11434
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_TLS_CERT_PATH=./nginx/certs/fullchain.pem
NGINX_TLS_KEY_PATH=./nginx/certs/privkey.pem
